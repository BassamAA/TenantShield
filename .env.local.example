# ── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE

# ── Stripe Price IDs (run `node scripts/setup-stripe.mjs` to create these) ───
STRIPE_PRICE_ONE_TIME=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_SUBSCRIPTION=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ONE_TIME_CAD=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_SUBSCRIPTION_CAD=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── App ───────────────────────────────────────────────────────────────────────
# Set to your Vercel URL in production
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Dev ───────────────────────────────────────────────────────────────────────
# Set to "true" to skip payment gate during local development
NEXT_PUBLIC_DEV_BYPASS_PAYMENT=true
